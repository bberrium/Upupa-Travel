---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Custom Tours — Upupa Travel" current="tours" description="Build a private Armenia itinerary around your own dates and interests.">
  <section class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-24 text-center">
    <div class="text-secondary text-label-md font-label-md tracking-widest uppercase mb-2">Tailor-Made</div>
    <h1 class="font-display-lg text-headline-md md:text-display-lg text-primary mb-6">Design Your Own Route</h1>
    <p class="text-on-surface-variant text-body-lg mb-10">
      Tell us your dates, interests, and pace, and we'll put together a private itinerary just for you —
      combining any of our tours, extra stops, or entirely new routes across Armenia.
    </p>
    <a href={`${base}#contact`} class="inline-block bg-secondary text-white px-8 py-4 font-label-md text-label-md hover:bg-on-secondary-fixed-variant transition-all uppercase tracking-widest">
      Start Your Enquiry
    </a>
  </section>
</BaseLayout>