<span class="material-symbols-outlined cursor-pointer hover:scale-110 transition-transform">star</span>
<span class="material-symbols-outlined cursor-pointer hover:scale-110 transition-transform">star</span>
<span class="material-symbols-outlined cursor-pointer hover:scale-110 transition-transform">star</span>
<span class="material-symbols-outlined cursor-pointer hover:scale-110 transition-transform">star</span>
<span class="material-symbols-outlined cursor-pointer hover:scale-110 transition-transform">star</span>
</div>
</div>
