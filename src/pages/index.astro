---
import BaseLayout from "../layouts/BaseLayout.astro";
import { TOURS } from "../data/tours.js";

const base = import.meta.env.BASE_URL;

// Add your 4 image URLs here:
const HERO_IMAGES = [
  "https://dynamic-media-cdn.tripadvisor.com/media/photo-o/33/e0/41/a0/caption.jpg",
  "https://lirp.cdn-website.com/d2942488/dms3rep/multi/opt/2Z6A8808-5760x3840-1920w.jpg",
  "https://dynamic-media-cdn.tripadvisor.com/media/photo-o/33/e0/41/9c/caption.jpg",
  "https://dynamic-media-cdn.tripadvisor.com/media/photo-o/33/e0/41/99/caption.jpg",
  "https://lirp.cdn-website.com/d2942488/dms3rep/multi/opt/2Z6A8868-5760x3840-1920w.jpg"
];
---

<BaseLayout title="Upupa Travel — Private Guides in Armenia" current="home">
<!-- Hero Section -->
<section class="relative h-[85vh] flex items-center overflow-hidden">
  <!-- Carousel Background Images -->
  <div class="absolute inset-0 z-0" id="hero-carousel">
    <div class="absolute inset-0 bg-black/40 z-10"></div>
      {HERO_IMAGES.map((imgUrl, index) => (
        <img
          src={imgUrl}
          alt="Armenia Travel"
          fetchpriority={index === 0 ? "high" : "auto"}
          loading={index === 0 ? "eager" : "lazy"}
          decoding={index === 0 ? "sync" : "async"}
          class={`hero-slide absolute inset-0 w-full h-full object-cover scale-105 transition-opacity duration-1000 ease-in-out [image-rendering:crisp-edges] ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        />
      ))}
  </div>

  <div class="relative z-20 w-full px-margin-desktop max-w-container-max mx-auto">
    <div class="max-w-3xl">
      <h1 class="text-white text-display-lg-mobile md:text-display-lg font-display-lg mb-stack-md leading-tight text-glow" data-t="hero_title">Travel boldly with Upupa</h1>
      <div class="flex flex-wrap gap-4">
        <a class="bg-secondary text-white px-8 py-4 rounded-lg font-bold hover:bg-secondary/90 transition-all flex items-center gap-2" href="#tours">
          <span data-t="hero_cta_explore" class="">Explore Tours</span> <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        <a class="bg-white/10 backdrop-blur-md border border-white/20 text-white px-8 py-4 rounded-lg font-bold hover:bg-white/20 transition-all" data-t="hero_cta_story" href="#about">
          Our Story
        </a>
      </div>
    </div>
  </div>

  <!-- Category Quick-links remain below -->
<!-- Category Quick-links -->
<div class="absolute bottom-0 left-0 right-0 z-30 transform translate-y-1/2 hidden md:block">
<div class="max-w-container-max mx-auto px-margin-desktop">
<div class="grid grid-cols-4 gap-6">
<!-- Box 1 -->
<a class="block bg-surface shadow-xl rounded-xl border border-outline-variant hover:-translate-y-2 hover:scale-105 transition-all duration-300 cursor-pointer h-64 relative overflow-hidden group/card" href="#tours">
<div class="relative z-20 h-full flex flex-col p-6">
<h3 class="font-headline-md text-primary mb-2 text-2xl leading-tight" data-t="cat_1_title">Day Tours</h3>
<p class="text-on-surface-variant text-sm" data-t="cat_1_desc">One-day private trips across Armenia.</p>
<div class="mt-auto h-28 -mx-6 -mb-6 overflow-hidden">
<img alt="Day Tours" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" src={`${base}images/hp1.jpg`}>
</div>
</div>
</a>
<!-- Box 2 -->
<a class="block bg-surface shadow-xl rounded-xl border border-outline-variant hover:-translate-y-2 hover:scale-105 transition-all duration-300 cursor-pointer h-64 relative overflow-hidden group/card" href="#tours">
<div class="relative z-20 h-full flex flex-col p-6">
<h3 class="font-headline-md text-primary mb-2 text-2xl leading-tight" data-t="cat_2_title">Multi-Day</h3>
<p class="text-on-surface-variant text-sm" data-t="cat_2_desc">Explore heritage in depth over 2-4 days.</p>
<div class="mt-auto h-28 -mx-6 -mb-6 overflow-hidden">
<img alt="Multi-Day" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" src={`${base}images/hp2.jpg`}>
</div>
</div>
</a>
<!-- Box 3 -->
<a class="block bg-surface shadow-xl rounded-xl border border-outline-variant hover:-translate-y-2 hover:scale-105 transition-all duration-300 cursor-pointer h-64 relative overflow-hidden group/card" href={`${base}custom-tour`}>
<div class="relative z-20 h-full flex flex-col p-6">
<h3 class="font-headline-md text-primary mb-2 text-2xl leading-tight" data-t="cat_3_title">Custom</h3>
<p class="text-on-surface-variant text-sm" data-t="cat_3_desc">Routes built around your specific dates.</p>
<div class="mt-auto h-28 -mx-6 -mb-6 overflow-hidden">
<img alt="Custom" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" src={`${base}images/hp3.jpg`}>
</div>
</div>
</a>
<!-- Box 4 -->
<a class="block bg-surface shadow-xl rounded-xl border border-outline-variant hover:-translate-y-2 hover:scale-105 transition-all duration-300 cursor-pointer h-64 relative overflow-hidden group/card" href={`${base}private-transfer`}>
<div class="relative z-20 h-full flex flex-col p-6">
<h3 class="font-headline-md text-primary mb-2 text-2xl leading-tight" data-t="cat_4_title">Transfers</h3>
<p class="text-on-surface-variant text-sm" data-t="cat_4_desc">Private drivers &amp; airport shuttle services.</p>
<div class="mt-auto h-28 -mx-6 -mb-6 overflow-hidden">
<img alt="Transfers" class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-110" src={`${base}images/ararat1.jpg`}>
</div>
</div>
</a>
</div>
</div>
</div>
</section>
<!-- Tours & Packages Section -->
<section class="py-section-padding px-margin-desktop max-w-container-max mx-auto mt-20" id="tours">
<div class="text-center mb-16">
<span class="text-secondary font-label-md text-label-md tracking-widest uppercase mb-2 block" data-t="tours_subtitle">Curated Experiences</span>
<h2 class="text-headline-md font-headline-md text-primary mb-4" data-t="tours_title">Tours &amp; Packages</h2>
<div class="w-12 h-1 bg-secondary mx-auto mb-6"></div>
<p class="text-on-surface-variant max-w-2xl mx-auto text-body-md" data-t="tours_desc">Discover the heart of Armenia through our specialized language-inclusive routes.</p>
</div>

<!-- Search / Filter Bar -->
<div class="flex flex-wrap gap-6 justify-center mb-12" id="tours-search">
  <!-- Box 1: People -->
  <div class="bg-surface-container-low border border-border-muted rounded-lg p-6">
    <label class="block text-label-md font-label-md text-primary uppercase mb-3">Number of people</label>
    <div class="flex items-center gap-2">
      <button type="button" id="ts-minus" class="w-9 h-9 border border-border-muted text-primary hover:bg-surface-container transition-colors" aria-label="Decrease">−</button>
      <input id="ts-people" type="number" min="1" max="19" value="2" class="w-14 text-center border border-border-muted rounded p-2 [appearance:textfield] [&::-webkit-outer-spin-button]:appearance-none [&::-webkit-inner-spin-button]:appearance-none" />
      <button type="button" id="ts-plus" class="w-9 h-9 border border-border-muted text-primary hover:bg-surface-container transition-colors" aria-label="Increase">+</button>
    </div>
  </div>

  <!-- Box 2: Unified Guide & Language Dropdown -->
  <div class="bg-surface-container-low border border-border-muted rounded-lg p-6 min-w-[220px]">
    <label class="block text-label-md font-label-md text-primary uppercase mb-3">Guide</label>
    <select id="ts-guide-lang" class="border border-border-muted rounded p-2.5 w-full bg-white text-primary font-medium focus:ring-2 focus:ring-secondary focus:outline-none">
      <option value="noGuide">No guide</option>
      <option value="en">🇬🇧 English</option>
      <option value="ru">🇷🇺 Russian</option>
      <option value="am">🇦🇲 Armenian</option>
    </select>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter" id="tours-grid"></div>
</section>

<script define:vars={{ TOURS, base }}>
  const grid = document.getElementById("tours-grid");
  const peopleInput = document.getElementById("ts-people");
  const minusBtn = document.getElementById("ts-minus");
  const plusBtn = document.getElementById("ts-plus");
  const guideLangSelect = document.getElementById("ts-guide-lang");

  // Background Hero Carousel Transition Logic
  const slides = document.querySelectorAll('.hero-slide');
  if (slides.length > 1) {
    let currentSlide = 0;
    setInterval(() => {
      slides[currentSlide].classList.remove('opacity-100');
      slides[currentSlide].classList.add('opacity-0');

      currentSlide = (currentSlide + 1) % slides.length;

      slides[currentSlide].classList.remove('opacity-0');
      slides[currentSlide].classList.add('opacity-100');
    }, 5000); // 5000ms = 5 seconds delay per image
  }

  function priceFor(pricing, people, withGuide) {
    if (!pricing) return null;
    const table = withGuide ? pricing.guide : pricing.noGuide;
    if (!table) return null;
    if (people < 1 || people > table.maxPeople) return null;
    if (people <= 10) return table[people];
    return table[10] + (people - 10) * table.extraPerPerson;
  }

  function formatAMD(n) {
    return n.toLocaleString("en-US") + " AMD";
  }

  function render() {
    const people = Math.max(1, Math.min(19, parseInt(peopleInput.value, 10) || 1));
    const selectedOption = guideLangSelect.value; // "noGuide" | "en" | "ru" | "am"
    const withGuide = selectedOption !== "noGuide";

    const visible = TOURS.filter((t) => {
      if (selectedOption === "noGuide") {
        // Must support tours without a guide
        if (!t.pricing?.noGuide) return false;
      } else {
        // Must support guided tours AND match selected language
        if (!t.pricing?.guide) return false;
        if (!t.languages.includes(selectedOption)) return false;
      }
      return true;
    });

    grid.innerHTML = "";

    if (visible.length === 0) {
      grid.innerHTML = `<p class="col-span-full text-center text-on-surface-variant py-8">No tours match those filters yet — try different options.</p>`;
      return;
    }

    visible.forEach((t) => {
      const total = priceFor(t.pricing, people, withGuide);
      const personLabel = people === 1 ? "person" : "persons";
      const priceLine = total
        ? `Price for ${people} ${personLabel}: ${formatAMD(total)}`
        : `Contact for price`;

      const tourHref = `${base}tours/${t.slug}`;
      const card = document.createElement("div");
      card.className = "group bg-surface border border-border-muted rounded-lg overflow-hidden transition-all hover:shadow-lg hover:-translate-y-1 flex flex-col";
      card.innerHTML = `
        <a href="${tourHref}" class="block h-64 overflow-hidden relative cursor-pointer" aria-label="View ${t.title} itinerary">
          <div class="absolute top-4 left-4 z-10">
            <span class="bg-secondary text-white text-caption px-3 py-1 rounded-full uppercase">${t.label}</span>
          </div>
          <img alt="${t.title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" src="${t.image}">
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
            <span class="opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300 bg-white text-primary font-label-md text-label-md px-5 py-2.5 rounded-full flex items-center gap-1.5 shadow-lg">
              View Itinerary <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
            </span>
          </div>
        </a>
        <div class="p-6 flex flex-col flex-grow">
          <a href="${tourHref}" class="inline-block">
            <h3 class="font-headline-sm text-primary mb-2 group-hover:text-secondary transition-colors cursor-pointer">${t.title}</h3>
          </a>
          <p class="text-on-surface-variant text-body-md mb-4 flex-grow">${t.desc}</p>
          <p class="text-primary font-label-md text-label-md">${priceLine}</p>
        </div>
      `;
      grid.appendChild(card);
    });
  }

  // Event Listeners
  minusBtn.addEventListener("click", () => {
    peopleInput.value = String(Math.max(1, parseInt(peopleInput.value, 10) - 1));
    render();
  });
  plusBtn.addEventListener("click", () => {
    peopleInput.value = String(Math.min(19, parseInt(peopleInput.value, 10) + 1));
    render();
  });
  peopleInput.addEventListener("input", render);
  guideLangSelect.addEventListener("change", render);

  render();
</script>


<!-- Minimalist About Section -->
