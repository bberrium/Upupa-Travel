---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Private Transfers — Upupa Travel" current="tours" description="Private drivers and airport transfer services in Armenia.">
  <section class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-24 text-center">
    <div class="text-secondary text-label-md font-label-md tracking-widest uppercase mb-2">Point to Point</div>
    <h1 class="font-display-lg text-headline-md md:text-display-lg text-primary mb-6">Private Drivers & Airport Transfers</h1>
    <p class="text-on-surface-variant text-body-lg mb-10">
      Skip the taxi lines. Book a private driver for airport pickup, drop-off, or point-to-point travel
      anywhere in Armenia — comfortable vehicles, fixed pricing, no surprises.
    </p>
    <a href={`${base}#contact`} class="inline-block bg-secondary text-white px-8 py-4 font-label-md text-label-md hover:bg-on-secondary-fixed-variant transition-all uppercase tracking-widest">
      Request a Transfer
    </a>
  </section>
</BaseLayout>