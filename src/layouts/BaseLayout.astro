---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SiteScripts from "../components/SiteScripts.astro";

interface Props {
  title: string;
  description?: string;
  home?: string;
  current?: "home" | "about" | "tours" | "gallery" | "reviews" | "contact";
}

const {
  title,
  description = "Premium private guide service in Armenia. Explore ancient monasteries, volcanic highlands, and hidden valleys with local experts.",
  home = "/",
  current = "home",
} = Astro.props;
---

<!doctype html>
<html class="scroll-smooth" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=block" rel="stylesheet" />
  </head>
  <body class="bg-background text-on-background font-body-md overflow-x-hidden">
    <Header home={home} current={current} />
    <main>
      <slot />
    </main>
    <Footer />
    <SiteScripts />
  </body>
</html>
